# ─────────────────────────────────────────────────────────────────────────────
# SwarmAudit Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API — get free key at https://console.groq.com
# Powers all 9 AI agents via Llama 3.1 70B
GROQ_API_KEY=your_groq_api_key_here

# Neon.tech PostgreSQL — free tier at https://neon.tech
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Allowed CORS origins (comma-separated, no spaces)
# Set to your Vercel/Netlify URL in production
# Example: https://swarmaudit.vercel.app,https://swarmaudit.netlify.app
ALLOWED_ORIGINS=http://localhost:3000

# Optional: GitHub token for cloning private repos or higher rate limits
# Get at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# Runtime configuration
ENVIRONMENT=development
PORT=8000
