# ─────────────────────────────────────────────────────────────────────────────
# SwarmAudit Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API — get free key at https://console.groq.com
# Powers all 9 AI agents via Llama 3.1 70B
GROQ_API_KEY=your_groq_api_key_here

# Neon.tech PostgreSQL — free tier at https://neon.tech
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Allowed CORS origins (comma-separated, no spaces)
# Set to your Vercel/Netlify URL in production
# Example: https://swarmaudit.vercel.app,https://swarmaudit.netlify.app
ALLOWED_ORIGINS=http://localhost:3000

# Optional: GitHub token for cloning private repos or higher rate limits
# Get at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# Runtime configuration
ENVIRONMENT=development
PORT=8000

# ─── Direction A — New feature flags ─────────────────────────────────────────

# Sandbox exploit validation (requires Docker socket mount in docker-compose.yml)
# Set to "false" on Render free tier (no Docker daemon available)
VALIDATION_ENABLED=true

# Max number of findings to validate in sandbox per audit (free tier: keep ≤5)
VALIDATION_MAX_FINDINGS=5

# Sandbox timeout per finding in seconds
VALIDATION_TIMEOUT_SECONDS=20

# GitHub PR Guardian — post Check Runs and PR comments
PR_GUARDIAN_ENABLED=true

# Secret used by the GitHub Actions pr-guardian.yml to authenticate against the backend
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SWARMAUDIT_INTERNAL_API_KEY=your_internal_api_key_here

# Webhook secret for verifying GitHub webhook payloads (optional, for future webhook support)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Public-facing URLs (used in PR comment deep-links and report links)
PUBLIC_FRONTEND_URL=https://swarm-audit.vercel.app
PUBLIC_BACKEND_URL=https://swarm-audit.onrender.com

# Default report language for compliance summaries (en, es, fr, de, ja)
DEFAULT_REPORT_LANGUAGE=en
