# ─────────────────────────────────────────────────────────────────────────────
# SwarmAudit Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Backend URL — your Render / Railway / Fly.io service URL
NEXT_PUBLIC_API_URL=https://swarmaudit-backend.onrender.com

# WebSocket URL — same host, wss:// protocol
NEXT_PUBLIC_WS_URL=wss://swarmaudit-backend.onrender.com
